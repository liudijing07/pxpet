{
  "name": "pxpet",
  "version": "1.0.0",
  "description": "Pixel art desktop pet powered by OpenClaw",
  "main": "main.js",
  "author": "liudijing07",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win"
  },
  "keywords": ["desktop-pet", "electron", "pixel-art", "openclaw", "ai"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/liudijing07/pxpet.git"
  },
  "build": {
    "appId": "com.pxpet.app",
    "productName": "pxpet",
    "icon": "icon.ico",
    "files": [
      "**/*",
      "!.env",
      "!chat-history.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "shortcutName": "pxpet"
    },
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron": "^35.2.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "marked": "^15.0.0"
  }
}
